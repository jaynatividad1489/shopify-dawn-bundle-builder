{{ 'bundle-builder.css' | asset_url | stylesheet_tag }}
<script src="{{ 'bundle-builder.js' | asset_url }}" defer></script>

<section
  class="bundle-builder color-{{ section.settings.color_scheme }}"
  id="BundleBuilder-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-discount="{{ section.settings.bundle_discount }}"
>

  <div class="page-width">

    {% if section.settings.heading != blank %}
      <div class="bundle-builder__header">

        <h2 class="bundle-builder__title">
          {{ section.settings.heading }}
        </h2>

        {% if section.settings.description != blank %}
          <div class="bundle-builder__description rte">
            {{ section.settings.description }}
          </div>
        {% endif %}

      </div>
    {% endif %}

    <div class="bundle-builder__products">

      {% for block in section.blocks %}

        {% assign bundle_product = block.settings.product %}

        {% if bundle_product != blank %}

          {% render 'bundle-product-card',
            product: bundle_product,
            block: block,
            section: section
          %}

        {% endif %}

      {% endfor %}

    </div>

    <div class="bundle-builder__summary">

      <div class="bundle-builder__row">
        <span>Subtotal</span>

        <span
          class="bundle-builder__subtotal"
          data-bundle-subtotal
        >
          {{ 0 | money }}
        </span>
      </div>

      <div class="bundle-builder__row">

        <span>
          Discount
          ({{ section.settings.bundle_discount }}%)
        </span>

        <span
          class="bundle-builder__discount"
          data-bundle-discount
        >
          {{ 0 | money }}
        </span>

      </div>

      <div class="bundle-builder__row bundle-builder__row--total">

        <strong>Total</strong>

        <strong
          class="bundle-builder__total"
          data-bundle-total
        >
          {{ 0 | money }}
        </strong>

      </div>

      <button
        type="button"
        class="button button--primary bundle-builder__button"
        data-add-bundle
      >
        {{ section.settings.button_label }}
      </button>

      <p
        class="bundle-builder__message"
        data-bundle-message
        hidden
      ></p>

    </div>

  </div>

</section>

{% schema %}
{
  "name": "Bundle Builder",
  "tag": "section",
  "class": "section",
  "settings": [

    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Build Your Bundle"
    },

    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Select your favorite products and save instantly.</p>"
    },

    {
      "type": "range",
      "id": "bundle_discount",
      "label": "Bundle Discount (%)",
      "min": 0,
      "max": 50,
      "step": 5,
      "default": 10
    },

    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Add Bundle to Cart"
    },

    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "background-1"
    }

  ],

  "blocks": [

    {
      "type": "product",

      "name": "Bundle Product",

      "settings": [

        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        }

      ]

    }

  ],

  "presets": [

    {
      "name": "Bundle Builder",

      "blocks": [

        {
          "type": "product"
        },

        {
          "type": "product"
        },

        {
          "type": "product"
        }

      ]

    }

  ]

}
{% endschema %}
