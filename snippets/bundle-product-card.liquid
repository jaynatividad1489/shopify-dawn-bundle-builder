{% liquid
  assign current_variant = product.selected_or_first_available_variant
%}

<div
  class="bundle-product"
  {{ block.shopify_attributes }}
  data-bundle-product
  data-product-id="{{ product.id }}"
>

  <div class="bundle-product__image">

    {% if product.featured_image %}

      {{
        product.featured_image
        | image_url: width: 700
        | image_tag:
          loading: 'lazy',
          widths: '180,360,540,700',
          sizes: '(min-width: 990px) 220px, 100vw',
          alt: product.featured_image.alt
      }}

    {% else %}

      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}

    {% endif %}

  </div>

  <div class="bundle-product__content">

    <h3 class="bundle-product__title">
      <a href="{{ product.url }}">
        {{ product.title }}
      </a>
    </h3>

    {% if product.vendor != blank %}
      <p class="bundle-product__vendor">
        {{ product.vendor }}
      </p>
    {% endif %}

    {% if product.has_only_default_variant %}

      <div
        class="bundle-product__price"
        data-price="{{ current_variant.price }}"
      >
        {{ current_variant.price | money }}
      </div>

      <input
        type="hidden"
        data-variant-id
        value="{{ current_variant.id }}"
      >

    {% else %}

      <label
        class="visually-hidden"
        for="BundleVariant-{{ block.id }}"
      >
        Variant
      </label>

      <select
        id="BundleVariant-{{ block.id }}"
        class="bundle-product__variants"
        data-variant-select
      >

        {% for variant in product.variants %}

          <option
            value="{{ variant.id }}"
            data-price="{{ variant.price }}"
            data-available="{{ variant.available }}"
            {% if variant.id == current_variant.id %}
              selected
            {% endif %}
          >

            {{ variant.title }}

            {% unless variant.available %}
              — Sold Out
            {% endunless %}

          </option>

        {% endfor %}

      </select>

      <div
        class="bundle-product__price"
        data-price-display
      >
        {{ current_variant.price | money }}
      </div>

    {% endif %}

    <div
      class="bundle-product__inventory"
      data-inventory-message
    >

      {% if current_variant.available %}
        <span class="bundle-product__available">
          In stock
        </span>
      {% else %}
        <span class="bundle-product__soldout">
          Sold Out
        </span>
      {% endif %}

    </div>

  </div>

  <script type="application/json" data-product-json>
    {{ product | json }}
  </script>

</div>
